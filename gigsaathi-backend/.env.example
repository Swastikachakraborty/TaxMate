# Environment Variables for GigSaathi Backend
# Copy this to .env and fill in real values

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gigsaathi?retryWrites=true&w=majority

# Fivetran MCP (optional for hackathon)
FIVETRAN_API_KEY=your_fivetran_api_key_here
FIVETRAN_API_SECRET=your_fivetran_api_secret_here

# Server
PORT=8000
HOST=0.0.0.0

# Environment
ENV=development
